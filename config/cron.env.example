# Copy to .agents-unite/cron.env (gitignored). Loaded by scripts/daily-run.sh before each run.
#
# Cron runs with a minimal environment — put secrets and PATH here.

# --- Recommended for unattended daily cron: local Ollama (no cloud auth) ---
# Set in .agents-unite/config.yaml:
#   agent_adapter: llm
#   llm_provider: ollama
#   llm_model: qwen2.5:0.5b
#   llm_base_url: http://127.0.0.1:11434/v1

# --- OR OpenAI-compatible API ---
# OPENAI_API_KEY=sk-...

# --- OR Cursor CLI (requires login or API key in cron — interactive login does NOT persist) ---
# CURSOR_API_KEY=...
# export PATH="${HOME}/.local/bin:${PATH}"

# GitHub CLI token for auto-PR (optional if gh auth login already works interactively)
# GH_TOKEN=...
