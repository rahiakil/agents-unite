{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agents-unite.example/schemas/sources.schema.json",
  "title": "Report Sources",
  "description": "JSON schema for validating structured source metadata companion files (sources.json).",
  "type": "object",
  "required": [
    "ticker",
    "date",
    "contributor",
    "generated_at",
    "sources"
  ],
  "additionalProperties": false,
  "properties": {
    "ticker": {
      "type": "string",
      "pattern": "^[A-Z]{1,5}$",
      "description": "Stock ticker symbol matching the parent report."
    },
    "date": {
      "type": "string",
      "format": "date",
      "description": "Report date in ISO 8601 format (YYYY-MM-DD)."
    },
    "contributor": {
      "type": "string",
      "minLength": 1,
      "description": "Identifier of the agent or pipeline that generated the sources file."
    },
    "generated_at": {
      "type": "string",
      "format": "date-time",
      "description": "UTC timestamp when the sources file was generated."
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/source"
      }
    }
  },
  "$defs": {
    "source": {
      "type": "object",
      "required": [
        "id",
        "type",
        "title",
        "publisher",
        "url",
        "published_at",
        "sentiment",
        "relevance_score",
        "summary"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$",
          "description": "Unique source identifier within the report."
        },
        "type": {
          "type": "string",
          "enum": ["news", "social", "filing", "analyst", "other"],
          "description": "Category of the source."
        },
        "title": {
          "type": "string",
          "minLength": 1,
          "description": "Human-readable title of the source."
        },
        "publisher": {
          "type": "string",
          "minLength": 1,
          "description": "Publishing organization or platform."
        },
        "url": {
          "type": "string",
          "format": "uri",
          "description": "Canonical URL for the source."
        },
        "published_at": {
          "type": "string",
          "format": "date-time",
          "description": "UTC timestamp when the source was published."
        },
        "sentiment": {
          "type": "string",
          "enum": ["bullish", "bearish", "neutral"],
          "description": "Sentiment classification for this individual source."
        },
        "relevance_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Relevance of the source to the ticker report (0–1)."
        },
        "summary": {
          "type": "string",
          "minLength": 1,
          "description": "Brief summary of the source content and its sentiment implications."
        }
      }
    }
  }
}
